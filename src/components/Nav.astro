---
const pathname = new URL(Astro.request.url).pathname;

const navItems = [
  { name: "Heim", href: "/" },
  { name: "Nánar um mig", href: "/details" },
  { name: "Verkefni", href: "/projects" },
  { name: "Tæki og tól", href: "/tools" },
  { name: "Færslur", href: "/posts" },
  { name: "Uppfærslusaga", href: "/changelog" },
];

console.log(pathname);

var index = -1;

navItems.forEach((navItem, i) => {
  if (pathname.includes(navItem.href)) {
    index = i;
  }
});

var displayVal = "block";
const transformVal = "translateY(" + index * 3.75 + "rem)";
if (index < 0) {
  displayVal = "none";
}
---

<nav>
  {
    navItems.map((i) => (
      <a href={i.href} transition:name={"a-" + i.href}>
        {i.name}
      </a>
    ))
  }
  <div
    style={{ transform: transformVal, display: displayVal }}
    transition:name="highlight"
  >
  </div>
</nav>

<script>
  function setupNav() {
    const nav = document.querySelector("nav");
    const div = nav?.querySelector("div");

    function rem() {
      return parseFloat(getComputedStyle(document.documentElement).fontSize);
    }

    if (nav && div) {
      const originalVal = div.style.transform;

      nav.addEventListener("mousemove", (event) => {
        const val = event.clientY - nav.getBoundingClientRect().top;
        const roundedVal =
          3.75 * Math.floor(val / ((nav.childElementCount - 1) * rem() * 0.65));
        div.style.transform = `translateY(${roundedVal}rem)`;
      });
      nav.addEventListener("mouseleave", () => {
        div.style.transform = originalVal;
      });
    }
  }
  document.addEventListener("astro:page-load", setupNav);
</script>

<style>
  nav {
    left: 20px;
    top: 20%;
    position: fixed;
    display: flex;
    flex-direction: column;
    background-color: white;
  }

  div {
    background-color: black;
    width: 100%;
    height: 3.75rem;

    position: absolute;
    top: 0rem;
    z-index: 0;
    pointer-events: none;

    transition: transform 0.6s ease-out;
  }

  nav:hover div, a:hover + div {
    transition: transform 0.2s ease-out;
  }

  a {
    z-index: 1;
    font-size: 1.25rem;
    color: white;
    text-decoration: none;
    padding: 1.25rem 10px;
    margin-left: 50px;
    margin-right: 30px;
    padding-right: auto;
    mix-blend-mode: difference;
  }
</style>
